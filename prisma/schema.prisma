generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          String?
  companyName   String?
  city          String?
  companyId     String?
  profileFilled Boolean   @default(false)
  // Card fields
  description   String?
  inn           String?
  website       String?
  categories    String[]
  objectTypes   String[]
  segment       String?
  regions       String[]
  hasProduction Boolean   @default(false)
  hasInstallation Boolean @default(false)
  minBudget     String?
  estimateTime  String?
  materials     String[]
  services      String[]
  verified      Boolean   @default(false)
  lastActive    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  @@index([role, profileFilled])
  @@index([city])
  @@index([segment])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Studio {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  website     String?
  inn         String?
  description String?
  city        String?
  segment     String?
  objectTypes String[]
  services    String[]
  verified    Boolean   @default(false)
  active      Boolean   @default(true)
  imageUrl    String?
  projectCount Int      @default(0)
  publications String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
  companyData CompanyData?

  @@index([segment])
  @@index([city])
  @@index([projectCount])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrls   String[]
  year        String?
  objectType  String?
  studioId    String
  studio      Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model CompanyData {
  id              String   @id @default(cuid())
  studioId        String   @unique
  studio          Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  ogrn            String?
  fullName        String?
  address         String?
  director        String?
  registrationDate String?
  status          String?
  revenue         String?
  profit          String?
  employees       Int?
  courtCasesCount Int      @default(0)
  courtCases      Json?
  contractsCount  Int      @default(0)
  contracts       Json?
  enforcementsCount Int    @default(0)
  enforcements    Json?
  rawCheckko      Json?
  rawDataNewton   Json?
  fetchedAt       DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  targetId  String
  targetType String  // "studio" or "contractor"
  createdAt DateTime @default(now())

  @@unique([userId, targetId, targetType])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  targetId  String?
  targetType String?
  meta      Json?
  createdAt DateTime @default(now())
}

model ProjectRequest {
  id          String   @id @default(cuid())
  userId      String
  role        String
  category    String
  location    String?
  objectType  String?
  level       String?
  urgency     String?
  description String?
  contactName String?
  contactPhone String?
  contactEmail String?
  hidePhone   Boolean  @default(false)
  status      String   @default("new")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ClaimCard {
  id          String   @id @default(cuid())
  userId      String
  companyName String
  inn         String?
  website     String?
  phone       String?
  contactName String?
  position    String?
  email       String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}
